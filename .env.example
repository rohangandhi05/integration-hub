# ─── Azure Service Bus ────────────────────────────────────────────────────────
# Get from Azure Portal → Service Bus Namespace → Shared Access Policies
AZURE_SB_CONNECTION_STRING=Endpoint=sb://YOUR_NAMESPACE.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=YOUR_KEY

# Queue names (must match what you created in Azure)
HR_QUEUE_NAME=hr-events
PAYROLL_QUEUE_NAME=payroll-events

# ─── API Security ─────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the gateway
API_KEYS=dev-key-1234,test-key-5678

# PGP passphrase for signing payloads
PGP_PASSPHRASE=change-me-in-production

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Dashboard ────────────────────────────────────────────────────────────────
VITE_GATEWAY_URL=http://localhost:3000
